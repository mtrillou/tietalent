{
  "manifest_version": 3,
  "name": "TieTalent Scout \u2014 Candidate Intelligence",
  "version": "1.0.0",
  "description": "Analyze candidate profiles instantly with AI. Get verified signals, hiring impact and recommendations directly on LinkedIn.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://tietalent.vercel.app/*",
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://www.indeed.com/*",
    "https://www.glassdoor.com/*",
    "https://www.welcometothejungle.com/*",
    "https://www.malt.fr/*",
    "https://www.malt.com/*",
    "https://www.toptal.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/in/*",
        "https://linkedin.com/in/*",
        "https://www.indeed.com/r/*",
        "https://www.glassdoor.com/Profile/*",
        "https://www.malt.fr/profile/*",
        "https://www.malt.com/profile/*",
        "https://www.toptal.com/resume/*",
        "https://www.welcometothejungle.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "sidebar.css"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}